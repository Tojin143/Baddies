--// LOAD RAYFIELD
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Window = Rayfield:CreateWindow({
    Name = "YoshidaaScript",
    LoadingTitle = "Script For Baddies",
    LoadingSubtitle = "by Yoshidaa",
    ConfigurationSaving = {Enabled = false}
})

--// VARIABLES
local FOVEnabled = false
local HitboxEnabled = false

--// LOADING SCREEN (LIKE YOUR PIC)
local function ShowMakuLoading()
    local player = game.Players.LocalPlayer
    local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))

    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(0, 500, 0, 300)
    frame.Position = UDim2.new(0.5, -250, 0.5, -150)
    frame.BackgroundColor3 = Color3.fromRGB(5,5,5)
    frame.BorderSizePixel = 2
    frame.BorderColor3 = Color3.fromRGB(0,255,0)

    -- TITLE
    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1,0,0,40)
    title.Text = "YOSHIDAA SCRIPTS Loading"
    title.TextColor3 = Color3.fromRGB(0,255,0)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.Code
    title.TextScaled = true

    -- SUBTITLE
    local sub = Instance.new("TextLabel", frame)
    sub.Size = UDim2.new(1,0,0,20)
    sub.Position = UDim2.new(0,0,0,40)
    sub.Text = "DOWNLOADING SCRIPT MODULES..."
    sub.TextColor3 = Color3.fromRGB(0,200,0)
    sub.BackgroundTransparency = 1
    sub.Font = Enum.Font.Code
    sub.TextScaled = true

    -- LOGS
    local logs = Instance.new("TextLabel", frame)
    logs.Size = UDim2.new(1,-20,0,140)
    logs.Position = UDim2.new(0,10,0,70)
    logs.BackgroundTransparency = 1
    logs.TextColor3 = Color3.fromRGB(0,255,0)
    logs.Font = Enum.Font.Code
    logs.TextXAlignment = Enum.TextXAlignment.Left
    logs.TextYAlignment = Enum.TextYAlignment.Top
    logs.Text = ""

    -- PROGRESS BAR BG
    local barBG = Instance.new("Frame", frame)
    barBG.Size = UDim2.new(1,-20,0,10)
    barBG.Position = UDim2.new(0,10,1,-40)
    barBG.BackgroundColor3 = Color3.fromRGB(20,20,20)

    local bar = Instance.new("Frame", barBG)
    bar.Size = UDim2.new(0,0,1,0)
    bar.BackgroundColor3 = Color3.fromRGB(0,255,0)

    local percent = Instance.new("TextLabel", frame)
    percent.Size = UDim2.new(1,0,0,20)
    percent.Position = UDim2.new(0,0,1,-60)
    percent.Text = "0%"
    percent.TextColor3 = Color3.fromRGB(0,255,0)
    percent.BackgroundTransparency = 1
    percent.Font = Enum.Font.Code

    -- WARNING BOX
    local warn = Instance.new("TextLabel", frame)
    warn.Size = UDim2.new(1,-20,0,40)
    warn.Position = UDim2.new(0,10,1,-100)
    warn.Text = "// CRITICAL WARNING\nDo not close while loading..."
    warn.TextColor3 = Color3.fromRGB(0,255,0)
    warn.BackgroundTransparency = 1
    warn.Font = Enum.Font.Code
    warn.TextScaled = true

    local messages = {
        "[INIT] Runtime started...",
        "Scanning Roblox...",
        "Locating DataModel...",
        "Attaching to Lua...",
        "[OK] Context acquired",
        "Decrypting...",
        "Bypassing...",
        "Finalizing..."
    }

    for i = 1,100 do
        bar.Size = UDim2.new(i/100,0,1,0)
        percent.Text = i.."%"

        if messages[i] then
            logs.Text = logs.Text .. "\n> "..messages[i]
        end

        task.wait(0.03)
    end

    task.wait(1)
    gui:Destroy()
end

--// TAB
local Tab = Window:CreateTab("Main")

--// FOV SLIDER + TOGGLE
local fovValue = 70

Tab:CreateSlider({
    Name = "FOV",
    Range = {70, 120},
    Increment = 1,
    CurrentValue = 70,
    Callback = function(Value)
        fovValue = Value
        if FOVEnabled then
            workspace.CurrentCamera.FieldOfView = fovValue
        end
    end
})

Tab:CreateToggle({
    Name = "Enable FOV",
    CurrentValue = false,
    Callback = function(Value)
        FOVEnabled = Value

        if Value then
            ShowMakuLoading() -- 🔥 loading when enabled
        end

        while FOVEnabled do
            workspace.CurrentCamera.FieldOfView = fovValue
            task.wait()
        end
    end
})

Tab:CreateToggle({
    Name = "Hitbox Expander",
    CurrentValue = false,
    Callback = function(Value)
        HitboxEnabled = Value

        if Value then
            ShowMakuLoading() 
        end

        while HitboxEnabled do
            for _,v in pairs(game.Players:GetPlayers()) do
                if v ~= game.Players.LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    v.Character.HumanoidRootPart.Size = Vector3.new(5,5,5)
                    v.Character.HumanoidRootPart.Transparency = 0.5
                    v.Character.HumanoidRootPart.BrickColor = BrickColor.new("Really red")
                    v.Character.HumanoidRootPart.Material = Enum.Material.Neon
                    v.Character.HumanoidRootPart.CanCollide = false
                end
            end
            task.wait(1)
        end
    end
})
